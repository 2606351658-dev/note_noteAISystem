# ============================================================
# NoteAI 后端 - Docker 构建忽略文件
# 这些文件/目录不会被复制到 Docker 镜像中
# ============================================================

# Maven 构建输出目录（由容器内构建生成，无需复制）
target/

# IDE 相关文件
.idea/
*.iml
*.ipr
*.iws
.classpath
.project
.settings

# 系统文件
.DS_Store
Thumbs.db

# Git 相关
.git/
.gitignore
.gitattributes

# Maven wrapper 的 jar 包（下载后较大，无需传入）
.mvn/wrapper/maven-wrapper.jar

# 日志文件
*.log

# 本地环境配置（如果有）
.env
.env.local
