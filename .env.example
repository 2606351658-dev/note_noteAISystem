# ============================================================
# NoteAI - 环境变量说明文件
#
# 用途：
#   这个文件列出了部署 NoteAI 项目需要配置的所有环境变量
#   在 Coolify 部署时，需要在 UI 界面中设置这些变量
#
# 使用方法：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 修改其中的值为你的实际配置
#   3. 注意：.env 文件已加入 .gitignore，不会提交到 Git
# ============================================================

# ============================================================
# 数据库配置（后端 application.properties 中引用）
# 对应格式：${DB_URL:默认值}、${DB_USERNAME:默认值} 等
# ============================================================

# MySQL 连接地址
# 格式：host:port/database
# 示例：
#   - Docker Compose：mysql:3306/aiclassnotetable
#   - 远程服务器：192.168.1.100:3306/aiclassnotetable
DB_URL=localhost:3306/aiclassnotetable

# 数据库用户名
DB_USERNAME=root

# 数据库密码
DB_PASSWORD=root

# ============================================================
# DeepSeek AI API 配置
# ============================================================

# DeepSeek API 密钥（在 https://platform.deepseek.com/ 获取）
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API 地址（一般不需要修改）
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# ============================================================
# 文件上传路径（可选）
# ============================================================

# 上传文件的存储路径（默认使用相对路径 ./file）
# Docker 部署时建议使用绝对路径或挂载卷
# FILE_UPLOAD_DIR=/app/file

# ============================================================
# 其他配置（可选）
# ============================================================

# 应用端口（默认 8081）
# SERVER_PORT=8081

# JPA 是否显示 SQL 日志（开发环境设为 true，生产环境建议 false）
# SPRING_JPA_SHOW_SQL=false
